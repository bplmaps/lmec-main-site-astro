---
import Layout from "../../layouts/Layout.astro";
import Card from "../../components/Article/Card.astro";
import Pagination from "../../components/Pagination.astro";
import ArticlesBrowser from "../../components/Articles/ArticlesBrowser.svelte";
import { fetchStoriesPaginated } from "../../lib/storyblok-fetch";

const currentPage = 1;
const articlesPerPage = 10;

let articles: any[] = [];
let totalPages = 0;
let totalArticles = 0;

try {
  const { stories, total } = await fetchStoriesPaginated({
    page: currentPage,
    per_page: articlesPerPage,
    starts_with: "main-site/",
    content_type: "article-page",
    sort_by: "content.publishDate:desc",
  });

  totalArticles = total;
  totalPages = Math.ceil(total / articlesPerPage) || 0;
  articles = stories.map((article: any) => {
    return {
      params: {
        title: article.name,
        description: article.content.description,
        slug: article.slug,
        headerImage: article.content.headerImage,
        publishedAt: article.content.publishDate,
        author: article.content.author,
        contentType: article.content.component,
      },
    };
  });
} catch (error) {
  console.error("Error fetching articles:", error);
  // Let the page render with empty data rather than crashing
}
---

<Layout
  title="Articles"
  description="Articles and posts that explore and explain our collections and initiatives"
  subheading="Articles and posts that explore and explain our collections and initiatives"
  pill="Article"
>
  <section class="section">
    <div class="row">
      <div class="col-12 order-2 order-lg-1">
        <!-- The browser's filter controls are server-rendered (disabled until
             hydration) so they sit in their final position from first paint;
             without JS they never become usable, so hide them entirely. -->
        <noscript>
          <style>
            #articles-browser-island {
              display: none;
            }
          </style>
        </noscript>
        <div id="articles-browser-island">
          <ArticlesBrowser client:idle totalCount={totalArticles} />
        </div>
        <!-- Static server-rendered listing: the crawlable/no-JS fallback.
             ArticlesBrowser hides it once the article index has loaded. -->
        <div id="articles-static-listing">
          <div class="row">
            {
              articles.map((article: any) => (
                <article class="col-sm-6 mb-5">
                  <Card
                    href={`/articles/${article.params.slug}`}
                    thumbnail={article.params.headerImage}
                    title={article.params.title}
                    description={article.params.description}
                    date={article.params.publishedAt}
                    author={article.params.author}
                  />
                </article>
              ))
            }
            <div class="col-12 mt-4">
              <Pagination
                urlBase="/articles/page"
                maxPagesToShow={5}
                currentPage={currentPage}
                totalPages={totalPages}
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
