---
import { SEO } from "astro-seo";
import Header from "../components/Layout/Header.astro";
import PageHeader from "../components/Layout/PageHeader.astro";
import Footer from "../components/Layout/Footer.astro";
import { analyticsConfig, analyticsIsConfigured } from "../config/analytics";
import "../styles/styles.scss";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  subheading?: string;
  pill?: string;
  noindex?: boolean;
}

const { title, description, image, subheading, pill, noindex } = Astro.props;

const siteTitle = "Leventhal Map &amp; Education Center at the Boston Public Library";
const siteImage = "https://ark.digitalcommonwealth.org/ark:/50959/3f463529r/thumbnail";

const metaTitle = title ? `${title} - ${siteTitle}` : `${siteTitle}`;
const metaDescription = description ? description : "";
const metaImage = image ? image : siteImage;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://www.leventhalmap.org").href;
const analyticsClientConfig = {
	enabled: analyticsIsConfigured,
	provider: analyticsConfig.provider,
	measurementId: analyticsConfig.measurementId,
	gtmContainerId: analyticsConfig.gtmContainerId,
	loadStrategy: analyticsConfig.loadStrategy,
	requireConsent: analyticsConfig.requireConsent,
	debug: analyticsConfig.debug,
	environment: analyticsConfig.environment,
	siteName: analyticsConfig.siteName,
};

const socialLinks = [
	{
		href: 'https://facebook.com/bplmaps',
		icon: 'facebook',
		label: 'Facebook',
	},
	{
		href: 'https://bsky.app/profile/bplmaps.bsky.social',
		icon: 'bluesky',
		label: 'Bluesky',
	},
	{
		href: 'https://instagram.com/bplmaps',
		icon: 'instagram',
		label: 'Instagram',
	},
	{
		href: 'https://www.youtube.com/c/LeventhalMapEducationCenter',
		icon: 'youtube',
		label: 'YouTube',
	},
	{
		href: 'https://www.flickr.com/photos/normanbleventhalmapcenter',
		icon: 'flickr',
		label: 'Flickr',
	},
	{
		href: 'https://github.com/bplmaps',
		icon: 'github',
		label: 'GitHub',
	},
	{
		href: 'https://mapstodon.space/@bplmaps',
		icon: 'mastodon',
		label: 'Mastodon',
	},
];

const menuLinks = [
	{
		text: 'Exhibitions',
		href: '/exhibitions',
	},
	{
		text: 'Collections',
		href: '/collections',
	},
	{
		text: 'Education',
		href: '/education',
	},
	{
		text: 'Research',
		href: '/research',
	},
	{
		text: 'Projects',
		href: '/projects',
	},
	{
		text: 'About',
		href: '/about',
	},
];

const secondaryMenuLinks = [
	{
		text: 'Events',
		href: '/event',
	},
	{
		text: 'Articles',
		href: '/articles',
	},
	{
		text: 'Contact Us',
		href: '/about/contact-connect',
	},
	{
		text: 'Donate Now',
		href: '/donate',
	},
	{
		text: 'Hours & Directions',
		href: '/about/hours-directions',
	},
	{
		text: 'Mission & History',
		href: '/about/mission-history',
	},
	{
		text: 'Accessibility',
		href: '/accessibility',
	},
	{
		text: 'Privacy Policy',
		href: '/privacy',
	},
	{
		text: 'BPL.org',
		href: 'https://bpl.org/',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
		<meta name="generator" content={Astro.generator} />
		<meta name="facebook-domain-verification" content="6q0qb8ylcx1vtfy18bpgaplv3mcwlp" />
		<link rel="preconnect" href="https://use.typekit.net" crossorigin />
		<link rel="preconnect" href="https://p.typekit.net" crossorigin />
		<link rel="preconnect" href="https://iiif.digitalcommonwealth.org" />
		<link rel="preconnect" href="https://a-us.storyblok.com" />
		<link rel="preconnect" href="https://cdn.fundraiseup.com" />
		<link rel="stylesheet" href="https://use.typekit.net/hnl4gif.css" />
		<script is:inline define:vars={{ analyticsClientConfig }}>
			window.dataLayer = window.dataLayer || [];
			window.gtag =
				window.gtag ||
				function () {
					window.dataLayer.push(arguments);
				};

			const hasConsent = () => {
				if (!analyticsClientConfig.requireConsent) return true;
				return localStorage.getItem("analytics-consent") === "granted";
			};

			const loadScript = (src) =>
				new Promise((resolve, reject) => {
					const script = document.createElement("script");
					script.async = true;
					script.src = src;
					script.onload = resolve;
					script.onerror = reject;
					document.head.appendChild(script);
				});

			const initGtag = async () => {
				if (!analyticsClientConfig.measurementId) return;
				await loadScript(
					`https://www.googletagmanager.com/gtag/js?id=${analyticsClientConfig.measurementId}`,
				);
				window.gtag("js", new Date());
				window.gtag("config", analyticsClientConfig.measurementId, {
					send_page_view: true,
					debug_mode:
						analyticsClientConfig.debug &&
						analyticsClientConfig.environment !== "production",
				});
			};

			const initGtm = async () => {
				if (!analyticsClientConfig.gtmContainerId) return;
				window.dataLayer.push({
					"gtm.start": new Date().getTime(),
					event: "gtm.js",
				});
				await loadScript(
					`https://www.googletagmanager.com/gtm.js?id=${analyticsClientConfig.gtmContainerId}`,
				);
			};

			const bootAnalytics = () => {
				if (!analyticsClientConfig.enabled || !hasConsent()) return;
				if (analyticsClientConfig.provider === "gtag") {
					void initGtag();
				}
				if (analyticsClientConfig.provider === "gtm") {
					void initGtm();
				}
			};

			if (analyticsClientConfig.loadStrategy === "immediate") {
				bootAnalytics();
			} else if (analyticsClientConfig.loadStrategy === "interaction") {
				const onInteraction = () => {
					bootAnalytics();
					window.removeEventListener("pointerdown", onInteraction);
					window.removeEventListener("keydown", onInteraction);
					window.removeEventListener("scroll", onInteraction);
				};
				window.addEventListener("pointerdown", onInteraction, { once: true });
				window.addEventListener("keydown", onInteraction, { once: true });
				window.addEventListener("scroll", onInteraction, { once: true });
			} else if ("requestIdleCallback" in window) {
				window.requestIdleCallback(() => bootAnalytics());
			} else {
				window.setTimeout(() => bootAnalytics(), 1500);
			}
		</script>
		<!-- Fundraise Up: world-class checkout experience for serious online fundraising.
		     Loading is deferred to idle / first interaction (same strategy as the
		     analytics loader above) to keep it off the critical rendering path. -->
		<script is:inline>(function () {
			var booted = false;
			var bootFundraiseUp = function () {
				if (booted) return;
				booted = true;
				(function (w, d, s, n, a) {
				if (!w[n]) {
					var l = 'call,catch,on,once,set,then,track'
					.split(','), i, o = function (n) {
						return 'function' == typeof n ? o.l.push([arguments]) && o
						: function () { return o.l.push([n, arguments]) && o }
					}, t = d.getElementsByTagName(s)[0],
					j = d.createElement(s); j.async = !0; j.src = 'https://cdn.fundraiseup.com/widget/' + a;
					t.parentNode.insertBefore(j, t); o.s = Date.now(); o.v = 4; o.h = w.location.href; o.l = [];
					for (i = 0; i < 7; i++)o[l[i]] = o(l[i]); w[n] = o
				}
				})(window, document, 'script', 'FundraiseUp', 'AGBYXHFF');
			};

			['pointerdown', 'keydown', 'touchstart', 'scroll'].forEach(function (evt) {
				window.addEventListener(evt, bootFundraiseUp, { once: true, passive: true });
			});
			if ('requestIdleCallback' in window) {
				window.requestIdleCallback(bootFundraiseUp);
			} else {
				window.setTimeout(bootFundraiseUp, 1500);
			}
		})();</script>
		<!-- End Fundraise Up -->
		<SEO
			title={metaTitle}
			description={metaDescription}
			noindex={noindex}
			openGraph={{
				basic: {
				title: `${metaTitle}`,
				type: "website",
				image: `${metaImage}`,
				url: canonicalURL
				},
			}}
			canonical={canonicalURL}
			extend={{
				link: [
					{ rel: "shortcut icon", href: "/favicon.png", type: "image/x-icon" },
					{ rel: "icon", href: "/favicon.png", type: "image/x-icon" },
					{ rel: "alternate", type: "application/rss+xml", title: "LMEC Articles", href: "/articles/rss.xml" },
				],
				meta: [
					{ name: "facebook-domain-verification", content: "6q0qb8ylcx1vtfy18bpgaplv3mcwlp" },
				],
			}}
		/>
	</head>
	<body>
		{analyticsIsConfigured && analyticsConfig.provider === "gtm" && analyticsConfig.gtmContainerId && (
			<>
				<!-- Google Tag Manager (noscript) -->
				<noscript>
					<iframe
						src={`https://www.googletagmanager.com/ns.html?id=${analyticsConfig.gtmContainerId}`}
						height="0"
						width="0"
						style="display:none;visibility:hidden"
					></iframe>
				</noscript>
				<!-- End Google Tag Manager (noscript) -->
			</>
		)}
		<a href="#main-content" class="visually-hidden-focusable skip-link">Skip to main content</a>
		<Header socialLinks={socialLinks} menuLinks={menuLinks} />
		{Astro.slots.has('root') ? (
			<Fragment>
				<slot name="root" />
				<div class="container">
					<slot />
				</div>
			</Fragment>
		) : (
			<Fragment>
				<PageHeader heading={title} paneltruckLayout={true} image={image} subheading={subheading} pill={pill} />
				<main id="main-content" class="container">
					<slot />
				</main>
			</Fragment>
		)}
		<Footer socialLinks={socialLinks} leftMenuLinks={menuLinks} rightMenuLinks={secondaryMenuLinks} />

		<script src="../scripts/app.js"></script>
	</body>
</html>
