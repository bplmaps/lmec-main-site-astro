---
const { paneltruckLayout, heading, subheading, pill, image } = Astro.props;

interface Props {
  paneltruckLayout?: boolean;
  heading?: string;
  subheading?: string;
  pill?: string;
  image?: string;
}
---

<section class={`page-title-section overlay ${!paneltruckLayout && 'page-title-section-tight'}`} style={paneltruckLayout ? `background-image: url(${image ? image : 'https://iiif.digitalcommonwealth.org/iiif/2/commonwealth:x633fc377/678,2866,8033,2018/1200,/0/default.jpg'});` : ''}>
  <div class="container">
    <div class="row">
      <div class="col-md-8">
        {heading &&
          <h1 class="h2 text-white page-header-fade-down">
            {heading}
          </h1>
        }
        {(subheading || pill) &&
          <p class="text-lighten page-header-fade-in page-subheader">
            {pill &&
              <span class="badge badge-light font-secondary me-3">
                {pill}
              </span>
            }
            {subheading}
          </p>
        }
      </div>
    </div>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .page-header-fade-down {
      animation: page-header-fade-down 1s both;
    }

    .page-header-fade-in {
      animation: page-header-fade-in 1s both;
    }
  }

  @keyframes page-header-fade-down {
    from {
      opacity: 0;
      transform: translateY(-100%);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes page-header-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>
